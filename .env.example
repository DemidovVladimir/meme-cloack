# meme-expert configuration. Copy to .env (gitignored). Rotate any key pasted in chat.

# --- Ingestion source -------------------------------------------------------
# helius_ws = Helius LaserStream WebSocket transactionSubscribe on the pump.fun
#   program (complete firehose: every token + trade, no sub cap, flat cost).
# pumpportal = legacy per-token metered stream (fallback).
INGEST_SOURCE=helius_ws

# Helius (LaserStream WebSocket — available on the standard plan; gRPC needs Business+).
# The URL is built as <HELIUS_WS_BASE>?api-key=<HELIUS_API_KEY> unless HELIUS_WS_URL
# is set explicitly. Keep the key out of chat; this file is gitignored.
HELIUS_API_KEY=
# HELIUS_WS_BASE=wss://mainnet.helius-rpc.com
# HELIUS_WS_URL=
PUMP_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
# 0 = keep every trade within RETENTION_HOURS (best for re-training: full outcomes).
# Set e.g. 30 to persist only each token's first 30 min of trades (live-screener disk bound).
EARLY_TRADE_WINDOW_MINUTES=0

# PumpPortal (only used when INGEST_SOURCE=pumpportal): metered, needs a funded linked wallet.
PUMPPORTAL_API_KEY=
PUMPPORTAL_WS_URL=wss://pumpportal.fun/api/data

# DuckDB files. hot.duckdb is held read-write by the ingester; the MCP server and
# `stats` read snapshot.duckdb (rewritten by the ingester every few minutes).
MEME_DB_PATH=./data/hot.duckdb
MEME_SNAPSHOT_PATH=./data/snapshot.duckdb

# Rolling window: rows older than this are pruned, tokens older are unsubscribed.
RETENTION_HOURS=24

# --- 40-minute survivor / early-rug tracking policy (cost + signal control) ---
# Subscribe to every new token's trades. Before SURVIVOR_AGE_MINUTES, drop a token
# the moment it looks dead (market cap below DEATH_DRAWDOWN_PCT of its peak, or no
# trades for DEATH_SILENCE_MINUTES). Survivors past that age are tracked to retention.
SURVIVOR_AGE_MINUTES=40
DEATH_DRAWDOWN_PCT=0.25
DEATH_SILENCE_MINUTES=5
# Hard ceiling on concurrent paid trade subscriptions (cost back-pressure).
MAX_ACTIVE_TRADE_SUBS=500

# Maintenance cadence. Lower SNAPSHOT_INTERVAL_MINUTES (e.g. 1) for fresher live
# screening — the screener's as-of clock keeps results correct regardless, this only
# reduces latency-to-surface. Higher = less snapshot I/O under the firehose.
PRUNE_INTERVAL_MINUTES=5
SNAPSHOT_INTERVAL_MINUTES=5
WRITER_FLUSH_MS=1000
WRITER_FLUSH_ROWS=500

# Logging (stderr).
RUST_LOG=info
